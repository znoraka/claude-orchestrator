{
  "name": "claude-orchestrator",
  "private": false,
  "license": "MIT",
  "version": "0.2.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build && pnpm build:mcp && pnpm build:agent && pnpm build:agent-opencode && pnpm build:agent-codex && pnpm build:title-server",
    "build:mcp": "esbuild src-tauri/resources/mcp-server.mjs --bundle --platform=node --format=esm --outfile=src-tauri/resources/mcp-server.bundle.mjs",
    "build:agent": "esbuild src-tauri/resources/agent-bridge.mjs --bundle --platform=node --format=esm --outfile=src-tauri/resources/agent-bridge.bundle.mjs",
    "build:agent-opencode": "esbuild src-tauri/resources/agent-bridge-opencode.mjs --bundle --platform=node --format=esm --outfile=src-tauri/resources/agent-bridge-opencode.bundle.mjs",
    "build:agent-codex": "esbuild src-tauri/resources/agent-bridge-codex.mjs --bundle --platform=node --format=esm --outfile=src-tauri/resources/agent-bridge-codex.bundle.mjs",
    "build:title-server": "esbuild src-tauri/resources/title-server.mjs --bundle --platform=node --format=esm --outfile=src-tauri/resources/title-server.bundle.mjs",
    "preview": "vite preview",
    "tauri": "tauri",
    "tauri:dev": "tauri dev --config src-tauri/tauri.dev.conf.json"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "dependencies": {
    "@codemirror/commands": "^6.10.2",
    "@codemirror/lang-css": "^6.3.1",
    "@codemirror/lang-html": "^6.4.11",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/lang-python": "^6.2.1",
    "@codemirror/lang-rust": "^6.0.2",
    "@codemirror/lang-yaml": "^6.1.2",
    "@codemirror/language": "^6.12.2",
    "@codemirror/search": "^6.6.0",
    "@codemirror/state": "^6.5.4",
    "@codemirror/view": "^6.39.16",
    "@fontsource-variable/dm-sans": "^5.2.8",
    "@pierre/diffs": "^1.0.11",
    "@replit/codemirror-vim": "^6.3.0",
    "@tanstack/react-virtual": "^3.13.21",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-notification": "^2.3.3",
    "@tauri-apps/plugin-opener": "^2",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-updater": "^2.10.0",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-search": "^0.16.0",
    "@xterm/xterm": "^5.5.0",
    "diff": "^8.0.3",
    "dompurify": "^3.3.1",
    "marked": "^17.0.4",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-window": "^2.2.7",
    "shiki": "^4.0.1",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.1.0",
    "@lezer/highlight": "^1.2.3",
    "@modelcontextprotocol/sdk": "^1.12.1",
    "@openai/codex-sdk": "^0.114.0",
    "@opencode-ai/sdk": "^1.2.18",
    "@tailwindcss/vite": "^4.1.0",
    "@tauri-apps/cli": "^2",
    "@types/diff": "^8.0.0",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^4.6.0",
    "esbuild": "^0.25.0",
    "tailwindcss": "^4.1.0",
    "typescript": "~5.8.3",
    "vite": "^7.0.4"
  }
}
