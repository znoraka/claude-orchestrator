{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Claude Session Manager",
  "version": "0.2.0",
  "identifier": "com.noe.claude-session-manager",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Claude Session Manager",
        "width": 1400,
        "height": 900,
        "decorations": true,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/znoraka/claude-orchestrator/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IERENzEzQkIwOEU3NTU5RjEKUldUeFdYV09zRHR4M1RQTThxVEJWVXpSQWV1OTFvaE1TMHNFb3Q5TUxYNC82MW5hWWRVZ3NWYlQK"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "resources/mcp-server.bundle.mjs",
      "resources/agent-bridge.bundle.mjs",
      "resources/agent-bridge-opencode.bundle.mjs",
      "resources/title-server.bundle.mjs"
    ]
  }
}
